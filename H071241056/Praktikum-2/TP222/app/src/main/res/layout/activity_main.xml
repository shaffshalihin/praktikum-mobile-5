<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="15dp"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/add"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:src="@drawable/add"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="100dp"
                android:layout_height="75dp"
                android:src="@drawable/instagram" />

            <ImageView
                android:layout_width="15dp"
                android:layout_height="15dp"
                android:layout_marginStart="5dp"
                android:src="@drawable/down_arrow" />
        </LinearLayout>

        <ImageView
            android:id="@+id/heart"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:src="@drawable/heart"/>

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <HorizontalScrollView
                android:id="@+id/storyScroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="10dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Story 1 -->
                    <LinearLayout
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginEnd="15dp">

                        <FrameLayout
                            android:layout_width="70dp"
                            android:layout_height="70dp"
                            android:background="@drawable/highlight_add"
                            android:layout_gravity="center">

                            <androidx.cardview.widget.CardView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                app:cardCornerRadius="35dp"
                                app:cardElevation="0dp"
                                app:cardBackgroundColor="@android:color/transparent"
                                app:strokeWidth="2dp"
                                app:strokeColor="#C0C0C0" />

                            <androidx.cardview.widget.CardView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_margin="5dp"
                                app:cardCornerRadius="35dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:scaleType="centerCrop"
                                    android:src="@drawable/post1" />
                            </androidx.cardview.widget.CardView>

                        </FrameLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:gravity="center"
                            android:text="story 1"
                            android:textSize="12sp"/>
                    </LinearLayout>

                    <!-- Story 2 -->
                    <LinearLayout
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginEnd="15dp">

                        <FrameLayout
                            android:layout_width="70dp"
                            android:layout_height="70dp"
                            android:background="@drawable/highlight_add"
                            android:layout_gravity="center">

                            <androidx.cardview.widget.CardView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                app:cardCornerRadius="35dp"
                                app:cardElevation="0dp"
                                app:cardBackgroundColor="@android:color/transparent"
                                app:strokeWidth="2dp"
                                app:strokeColor="#C0C0C0" />

                            <androidx.cardview.widget.CardView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_margin="5dp"
                                app:cardCornerRadius="35dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:scaleType="centerCrop"
                                    android:src="@drawable/post2" />
                            </androidx.cardview.widget.CardView>

                        </FrameLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:gravity="center"
                            android:text="story 2"
                            android:textSize="12sp"/>
                    </LinearLayout>

                    <!-- Story 3 -->
                    <LinearLayout
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginEnd="15dp">

                        <FrameLayout
                            android:layout_width="70dp"
                            android:layout_height="70dp"
                            android:background="@drawable/highlight_add"
                            android:layout_gravity="center">

                            <androidx.cardview.widget.CardView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                app:cardCornerRadius="35dp"
                                app:cardElevation="0dp"
                                app:cardBackgroundColor="@android:color/transparent"
                                app:strokeWidth="2dp"
                                app:strokeColor="#C0C0C0" />

                            <androidx.cardview.widget.CardView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_margin="5dp"
                                app:cardCornerRadius="35dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:scaleType="centerCrop"
                                    android:src="@drawable/post3" />
                            </androidx.cardview.widget.CardView>

                        </FrameLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:gravity="center"
                            android:text="story 3"
                            android:textSize="12sp"/>
                    </LinearLayout>

                    <!-- Story 4 -->
                    <LinearLayout
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginEnd="15dp">

                        <FrameLayout
                            android:layout_width="70dp"
                            android:layout_height="70dp"
                            android:background="@drawable/highlight_add"
                            android:layout_gravity="center">

                            <androidx.cardview.widget.CardView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                app:cardCornerRadius="35dp"
                                app:cardElevation="0dp"
                                app:cardBackgroundColor="@android:color/transparent"
                                app:strokeWidth="2dp"
                                app:strokeColor="#C0C0C0" />

                            <androidx.cardview.widget.CardView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_margin="5dp"
                                app:cardCornerRadius="35dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:scaleType="centerCrop"
                                    android:src="@drawable/post4" />
                            </androidx.cardview.widget.CardView>

                        </FrameLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:gravity="center"
                            android:text="story 4"
                            android:textSize="12sp"/>
                    </LinearLayout>

                    <!-- Story 5 -->
                    <LinearLayout
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginEnd="15dp">

                        <FrameLayout
                            android:layout_width="70dp"
                            android:layout_height="70dp"
                            android:background="@drawable/highlight_add"
                            android:layout_gravity="center">

                            <androidx.cardview.widget.CardView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                app:cardCornerRadius="35dp"
                                app:cardElevation="0dp"
                                app:cardBackgroundColor="@android:color/transparent"
                                app:strokeWidth="2dp"
                                app:strokeColor="#C0C0C0" />

                            <androidx.cardview.widget.CardView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_margin="5dp"
                                app:cardCornerRadius="35dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:scaleType="centerCrop"
                                    android:src="@drawable/post7" />
                            </androidx.cardview.widget.CardView>

                        </FrameLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:gravity="center"
                            android:text="story 5"
                            android:textSize="12sp"/>
                    </LinearLayout>

                </LinearLayout>

            </HorizontalScrollView>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPosts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:menu="@menu/bottom_navigation_menu"
        android:background="#FFFFFF"
        app:itemIconTint="@null"/>

</LinearLayout>