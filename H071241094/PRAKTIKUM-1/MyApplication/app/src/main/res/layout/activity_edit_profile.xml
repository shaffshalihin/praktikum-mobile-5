<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="#000000">

            <TextView
                android:id="@+id/tv_cancel"
                android:layout_width="48dp"
                android:layout_height="match_parent"
                android:layout_alignParentStart="true"
                android:gravity="center_vertical"
                android:text="‹"
                android:textSize="28sp"
                android:textColor="#FFFFFF"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Edit profil"
                android:textStyle="bold"
                android:textSize="17sp"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/tv_done"
                android:layout_width="64dp"
                android:layout_height="match_parent"
                android:layout_alignParentEnd="true"
                android:gravity="center_vertical|end"
                android:text="Selesai"
                android:textSize="15sp"
                android:textColor="#0095F6"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />

        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#2A2A2A" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="28dp"
            android:paddingBottom="24dp"
            android:background="#000000">

            <FrameLayout
                android:layout_width="90dp"
                android:layout_height="90dp">

                <ImageView
                    android:id="@+id/iv_edit_profile_pic"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:layout_gravity="center"
                    android:src="@drawable/profil"
                    android:scaleType="centerCrop"
                    android:background="@drawable/oval_clip"
                    android:clipToOutline="true"
                    android:outlineProvider="background"/>

            </FrameLayout>

            <TextView
                android:id="@+id/tv_edit_photo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Edit foto atau avatar"
                android:textSize="14sp"
                android:textColor="#0095F6"
                android:paddingTop="14dp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#2A2A2A" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="#000000">
            <TextView
                android:id="@+id/label_name"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true"
                android:text="Nama"
                android:textSize="14sp"
                android:textColor="#FFFFFF" />
            <EditText
                android:id="@+id/et_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_toEndOf="@id/label_name"
                android:layout_marginStart="8dp"
                android:hint="Nama"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:textColorHint="#666666"
                android:background="@null"
                android:paddingEnd="16dp" />
        </RelativeLayout>

        <View android:layout_width="match_parent" android:layout_height="0.5dp"
            android:background="#2A2A2A" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="#000000">
            <TextView
                android:id="@+id/label_username"
                android:layout_width="110dp"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true"
                android:text="Nama pengguna"
                android:textSize="14sp"
                android:textColor="#FFFFFF" />
            <EditText
                android:id="@+id/et_username"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_toEndOf="@id/label_username"
                android:layout_marginStart="8dp"
                android:text="angelctrna_"
                android:textSize="14sp"
                android:textColor="#888888"
                android:background="@null"
                android:paddingEnd="16dp" />
        </RelativeLayout>

        <View android:layout_width="match_parent" android:layout_height="0.5dp"
            android:background="#2A2A2A" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="#000000">
            <TextView
                android:id="@+id/label_pronouns"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true"
                android:text="Kata ganti"
                android:textSize="14sp"
                android:textColor="#FFFFFF" />
            <EditText
                android:id="@+id/et_pronouns"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_toEndOf="@id/label_pronouns"
                android:layout_marginStart="8dp"
                android:hint="Kata ganti"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:textColorHint="#666666"
                android:background="@null"
                android:paddingEnd="16dp" />
        </RelativeLayout>

        <View android:layout_width="match_parent" android:layout_height="0.5dp"
            android:background="#2A2A2A" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="#000000">
            <TextView
                android:id="@+id/label_bio"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true"
                android:text="Bio"
                android:textSize="14sp"
                android:textColor="#FFFFFF" />
            <EditText
                android:id="@+id/et_bio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_toEndOf="@id/label_bio"
                android:layout_marginStart="8dp"
                android:hint="Bio"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:textColorHint="#666666"
                android:background="@null"
                android:paddingEnd="16dp" />
        </RelativeLayout>

        <View android:layout_width="match_parent" android:layout_height="0.5dp"
            android:background="#2A2A2A" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="#000000">
            <TextView
                android:id="@+id/label_tautan"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true"
                android:text="Tautan"
                android:textSize="14sp"
                android:textColor="#FFFFFF" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_toEndOf="@id/label_tautan"
                android:layout_marginStart="8dp"
                android:text="Tambahkan tautan"
                android:textSize="14sp"
                android:textColor="#666666"
                android:paddingEnd="16dp" />
        </RelativeLayout>

        <View android:layout_width="match_parent" android:layout_height="0.5dp"
            android:background="#2A2A2A" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="#000000">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true"
                android:text="Banner"
                android:textSize="14sp"
                android:textColor="#FFFFFF" />
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_alignParentEnd="true"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2"
                    android:textSize="14sp"
                    android:textColor="#888888"
                    android:layout_marginEnd="6dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="22sp"
                    android:textColor="#888888" />
            </LinearLayout>
        </RelativeLayout>

        <View android:layout_width="match_parent" android:layout_height="0.5dp"
            android:background="#2A2A2A" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="#000000">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true"
                android:text="Musik"
                android:textSize="14sp"
                android:textColor="#FFFFFF" />
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_alignParentEnd="true"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hindia · Alexandra"
                    android:textSize="14sp"
                    android:textColor="#888888"
                    android:layout_marginEnd="8dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✕"
                    android:textSize="15sp"
                    android:textColor="#FFFFFF" />
            </LinearLayout>
        </RelativeLayout>

        <View android:layout_width="match_parent" android:layout_height="0.5dp"
            android:background="#2A2A2A" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="#000000">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true"
                android:text="Tampilkan banner Threads"
                android:textSize="14sp"
                android:textColor="#FFFFFF" />
            <Switch
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_alignParentEnd="true"
                android:checked="true"
                android:thumbTint="#FFFFFF"
                android:trackTint="#3A3A3A" />
        </RelativeLayout>

        <View android:layout_width="match_parent" android:layout_height="0.5dp"
            android:background="#2A2A2A" />

        <RelativeLayout
            android:id="@+id/row_gender"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="#000000"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true"
                android:text="Jenis kelamin"
                android:textSize="14sp"
                android:textColor="#FFFFFF" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_alignParentEnd="true"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_gender_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Perempuan"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="22sp"
                    android:textColor="#888888" />
            </LinearLayout>
        </RelativeLayout>

        <View android:layout_width="match_parent" android:layout_height="0.5dp"
            android:background="#2A2A2A" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Beralih ke akun profesional"
            android:textSize="14sp"
            android:textColor="#0095F6"
            android:paddingStart="16dp"
            android:paddingTop="18dp"
            android:paddingBottom="18dp"
            android:background="#000000" />

        <View android:layout_width="match_parent" android:layout_height="0.5dp"
            android:background="#2A2A2A" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pengaturan informasi pribadi"
            android:textSize="14sp"
            android:textColor="#0095F6"
            android:paddingStart="16dp"
            android:paddingTop="18dp"
            android:paddingBottom="18dp"
            android:background="#000000" />

        <View android:layout_width="match_parent" android:layout_height="0.5dp"
            android:background="#2A2A2A" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tampilkan bahwa profil Anda sudah diverifikasi"
            android:textSize="14sp"
            android:textColor="#0095F6"
            android:paddingStart="16dp"
            android:paddingTop="18dp"
            android:paddingBottom="36dp"
            android:background="#000000" />

    </LinearLayout>
</ScrollView>