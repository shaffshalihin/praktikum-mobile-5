<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A"
    android:orientation="vertical">

    <!-- ===== TOOLBAR ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="#0A0A0A">

        <ImageView
            android:id="@+id/btn_back_add_post"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/logo12"
            app:tint="#FFFFFF"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Kembali"
            android:padding="4dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Postingan Baru"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold" />

    </LinearLayout>


    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#2A2A2A" />

    <!-- ===== KONTEN SCROLL ===== -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== AREA PREVIEW GAMBAR ===== -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="380dp"
                android:background="#111111"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/iv_upload_preview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerInside"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="Pilih Gambar" />

                <LinearLayout
                    android:id="@+id/tv_pick_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:clickable="false">

                    <ImageView
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:src="@android:drawable/ic_menu_camera"
                        app:tint="#444444"
                        android:contentDescription="Kamera" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Ketuk untuk memilih foto"
                        android:textColor="#666666"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="dari galeri perangkat Anda"
                        android:textColor="#444444"
                        android:textSize="13sp" />

                </LinearLayout>

            </FrameLayout>

            <!-- ===== SECTION CAPTION ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="14dp"
                android:gravity="top">

                <androidx.cardview.widget.CardView
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    app:cardCornerRadius="19dp"
                    app:cardElevation="0dp">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/foto_profil" />
                </androidx.cardview.widget.CardView>

                <!-- Input caption -->
                <EditText
                    android:id="@+id/et_caption_post"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:background="@null"
                    android:hint="Tulis keterangan..."
                    android:textColor="#FFFFFF"
                    android:textColorHint="#555555"
                    android:textSize="15sp"
                    android:minLines="3"
                    android:gravity="top"
                    android:inputType="textMultiLine|textCapSentences"
                    android:maxLines="8" />

            </LinearLayout>

            <!-- ===== TOMBOL BAGIKAN ===== -->
            <Button
                android:id="@+id/btn_submit_post"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="32dp"
                android:backgroundTint="#0095F6"
                android:text="Bagikan"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textAllCaps="false" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>