<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarEdit"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:background="#FFFFFF"
        app:titleTextColor="#000000"
        app:titleTextAppearance="@style/ToolbarTitleStyle"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.7dp"
        android:background="#DBDBDB"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Foto + "Ganti foto profil" -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="24dp"
                android:paddingBottom="16dp"
                android:background="#FFFFFF">

                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:id="@+id/imgProfileEdit"
                        android:layout_width="96dp"
                        android:layout_height="96dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_default_avatar"
                        android:background="@drawable/circle_stroke_bg"
                        android:clipToOutline="true"
                        android:clickable="true"
                        android:focusable="true"/>

                    <!-- Ikon kamera di pojok kanan bawah -->
                    <FrameLayout
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/circle_bg_dark"
                        android:layout_gravity="bottom|end">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_camera"
                            android:layout_gravity="center"/>
                    </FrameLayout>
                </FrameLayout>

                <TextView
                    android:id="@+id/tvChangePhoto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ganti foto profil"
                    android:textColor="#0095F6"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:paddingTop="12dp"
                    android:paddingBottom="4dp"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.7dp" android:background="#DBDBDB"/>

            <!-- ── FIELD: Nama ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nama"
                    android:textColor="#888888"
                    android:textSize="12sp"/>

                <EditText
                    android:id="@+id/etName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Nama"
                    android:textColor="#000000"
                    android:textColorHint="#BBBBBB"
                    android:textSize="16sp"
                    android:background="@null"
                    android:paddingVertical="8dp"
                    android:inputType="textPersonName"
                    android:imeOptions="actionNext"
                    android:maxLines="1"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.7dp" android:background="#DBDBDB"/>

            <!-- ── FIELD: Username ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Username"
                    android:textColor="#888888"
                    android:textSize="12sp"/>

                <EditText
                    android:id="@+id/etUsername"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Username"
                    android:textColor="#000000"
                    android:textColorHint="#BBBBBB"
                    android:textSize="16sp"
                    android:background="@null"
                    android:paddingVertical="8dp"
                    android:inputType="textNoSuggestions"
                    android:imeOptions="actionNext"
                    android:maxLines="1"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.7dp" android:background="#DBDBDB"/>

            <!-- ── FIELD: Bio ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bio"
                    android:textColor="#888888"
                    android:textSize="12sp"/>

                <EditText
                    android:id="@+id/etBio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Tulis bio..."
                    android:textColor="#000000"
                    android:textColorHint="#BBBBBB"
                    android:textSize="16sp"
                    android:background="@null"
                    android:paddingVertical="8dp"
                    android:inputType="textMultiLine"
                    android:gravity="top|start"
                    android:minLines="3"
                    android:maxLines="6"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.7dp" android:background="#DBDBDB"/>

            <!-- ── FIELD: Website ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Website"
                    android:textColor="#888888"
                    android:textSize="12sp"/>

                <EditText
                    android:id="@+id/etWebsite"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Tambahkan link"
                    android:textColor="#000000"
                    android:textColorHint="#BBBBBB"
                    android:textSize="16sp"
                    android:background="@null"
                    android:paddingVertical="8dp"
                    android:inputType="textWebEditText"
                    android:imeOptions="actionDone"
                    android:maxLines="1"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.7dp" android:background="#DBDBDB"/>

            <!-- Tombol Simpan -->
            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Simpan"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:letterSpacing="0"
                android:background="@drawable/btn_blue_rounded"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="24dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                style="@style/Widget.AppCompat.Button"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
