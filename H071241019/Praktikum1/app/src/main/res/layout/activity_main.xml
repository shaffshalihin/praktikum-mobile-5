<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ==================== HEADER ==================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="hodo.id"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@android:color/black" />

            <!-- Ikon bell (pake emoji karena ic_bell mungkin missing) -->
            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:text="🔔"
                android:textSize="20sp"
                android:layout_marginEnd="16dp" />

            <!-- Ikon menu (pake emoji) -->
            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:text="⋮"
                android:textSize="24sp"
                android:gravity="center" />
        </LinearLayout>

        <!-- ==================== PROFILE INFO ==================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp">

            <!-- Foto Profil -->
            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginEnd="20dp">

                <ImageView
                    android:id="@+id/iv_foto_profil"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/ic_hodo_profile"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_lingkaran_abu" />

                <!-- Ikon plus (pake emoji) -->
                <TextView
                    android:id="@+id/tv_ganti_foto"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="bottom|end"
                    android:text="➕"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:background="@drawable/bg_putih_lingkaran" />
            </FrameLayout>

            <!-- Stats -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="10dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tv_posts"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="12"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/black" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="posts"
                        android:textSize="12sp"
                        android:textColor="#8e8e8e" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tv_followers"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="77"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/black" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="followers"
                        android:textSize="12sp"
                        android:textColor="#8e8e8e" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tv_following"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/black" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="following"
                        android:textSize="12sp"
                        android:textColor="#8e8e8e" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ==================== BIO SECTION ==================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HODO.id – Eat With Rhythm"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@android:color/black" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kitchen/cooking"
                android:textSize="13sp"
                android:textColor="@android:color/black" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Homemade rice bowls bento 🍴, cooked by order"
                android:textSize="13sp"
                android:textColor="@android:color/black" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Order via WhatsApp 📱"
                android:textSize="13sp"
                android:textColor="@android:color/black" />

            <TextView
                android:id="@+id/tv_link"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="linktr.ee/HODO.id"
                android:textSize="13sp"
                android:textColor="#00376b" />
        </LinearLayout>

        <!-- ==================== ACTION BUTTONS ==================== -->
        <LinearLayout
            android:id="@+id/btn_edit_profile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="35dp"
                android:layout_weight="1"
                android:text="Follow"
                android:gravity="center"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:background="@drawable/bg_button_blue_curvy"
                android:layout_marginEnd="4dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="35dp"
                android:layout_weight="1"
                android:text="Message"
                android:gravity="center"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@android:color/black"
                android:background="@drawable/bg_button_gray_curvy"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp" />

            <TextView
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:text="+8"
                android:gravity="center"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@android:color/black"
                android:background="@drawable/bg_button_gray_curvy" />
        </LinearLayout>

        <!-- ==================== HIGHLIGHT STORIES ==================== -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="12dp"
            android:paddingStart="16dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Story 1 -->
                <LinearLayout
                    android:layout_width="70dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginEnd="16dp">

                    <FrameLayout
                        android:layout_width="60dp"
                        android:layout_height="60dp">

                        <View
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:background="@drawable/bg_highlight_gradient" />

                        <ImageView
                            android:layout_width="54dp"
                            android:layout_height="54dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_story_1"
                            android:scaleType="centerCrop"
                            android:clipToOutline="true"
                            android:outlineProvider="background"
                            android:background="@drawable/bg_circle" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sahoor"
                        android:textSize="11sp"
                        android:textColor="#262626"
                        android:layout_marginTop="4dp"
                        android:maxLines="1"
                        android:ellipsize="end" />
                </LinearLayout>

                <!-- Story 2 -->
                <LinearLayout
                    android:layout_width="70dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginEnd="16dp">

                    <FrameLayout
                        android:layout_width="60dp"
                        android:layout_height="60dp">

                        <View
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:background="@drawable/bg_highlight_gradient" />

                        <ImageView
                            android:layout_width="54dp"
                            android:layout_height="54dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_story_2"
                            android:scaleType="centerCrop"
                            android:clipToOutline="true"
                            android:outlineProvider="background"
                            android:background="@drawable/bg_circle" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Iftar"
                        android:textSize="11sp"
                        android:textColor="#262626"
                        android:layout_marginTop="4dp"
                        android:maxLines="1"
                        android:ellipsize="end" />
                </LinearLayout>

                <!-- Story 3 -->
                <LinearLayout
                    android:layout_width="70dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginEnd="16dp">

                    <FrameLayout
                        android:layout_width="60dp"
                        android:layout_height="60dp">

                        <View
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:background="@drawable/bg_highlight_gradient" />

                        <ImageView
                            android:layout_width="54dp"
                            android:layout_height="54dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_story_3"
                            android:scaleType="centerCrop"
                            android:clipToOutline="true"
                            android:outlineProvider="background"
                            android:background="@drawable/bg_circle" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bulk"
                        android:textSize="11sp"
                        android:textColor="#262626"
                        android:layout_marginTop="4dp"
                        android:maxLines="1"
                        android:ellipsize="end" />
                </LinearLayout>

                <!-- Story 4 -->
                <LinearLayout
                    android:layout_width="70dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginEnd="16dp">

                    <FrameLayout
                        android:layout_width="60dp"
                        android:layout_height="60dp">

                        <View
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:background="@drawable/bg_highlight_gradient" />

                        <ImageView
                            android:layout_width="54dp"
                            android:layout_height="54dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_story_4"
                            android:scaleType="centerCrop"
                            android:clipToOutline="true"
                            android:outlineProvider="background"
                            android:background="@drawable/bg_circle" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@daffa"
                        android:textSize="11sp"
                        android:textColor="#262626"
                        android:layout_marginTop="4dp"
                        android:maxLines="1"
                        android:ellipsize="end" />
                </LinearLayout>

                <!-- Story 5 -->
                <LinearLayout
                    android:layout_width="70dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginEnd="16dp">

                    <FrameLayout
                        android:layout_width="60dp"
                        android:layout_height="60dp">

                        <View
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:background="@drawable/bg_highlight_gradient" />

                        <ImageView
                            android:layout_width="54dp"
                            android:layout_height="54dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_story_5"
                            android:scaleType="centerCrop"
                            android:clipToOutline="true"
                            android:outlineProvider="background"
                            android:background="@drawable/bg_circle" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ready"
                        android:textSize="11sp"
                        android:textColor="#262626"
                        android:layout_marginTop="4dp"
                        android:maxLines="1"
                        android:ellipsize="end" />
                </LinearLayout>

                <!-- Story 6 -->
                <LinearLayout
                    android:layout_width="70dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginEnd="16dp">

                    <FrameLayout
                        android:layout_width="60dp"
                        android:layout_height="60dp">

                        <View
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:background="@drawable/bg_highlight_gradient" />

                        <ImageView
                            android:layout_width="54dp"
                            android:layout_height="54dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_story_6"
                            android:scaleType="centerCrop"
                            android:clipToOutline="true"
                            android:outlineProvider="background"
                            android:background="@drawable/bg_circle" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Stove"
                        android:textSize="11sp"
                        android:textColor="#262626"
                        android:layout_marginTop="4dp"
                        android:maxLines="1"
                        android:ellipsize="end" />
                </LinearLayout>

                <!-- Story 7 -->
                <LinearLayout
                    android:layout_width="70dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginEnd="16dp">

                    <FrameLayout
                        android:layout_width="60dp"
                        android:layout_height="60dp">

                        <View
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:background="@drawable/bg_highlight_gradient" />

                        <ImageView
                            android:layout_width="54dp"
                            android:layout_height="54dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_story_7"
                            android:scaleType="centerCrop"
                            android:clipToOutline="true"
                            android:outlineProvider="background"
                            android:background="@drawable/bg_circle" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pudding"
                        android:textSize="11sp"
                        android:textColor="#262626"
                        android:layout_marginTop="4dp"
                        android:maxLines="1"
                        android:ellipsize="end" />
                </LinearLayout>
            </LinearLayout>
        </HorizontalScrollView>

        <!-- ==================== TAB LAYOUT ==================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:weightSum="3">

            <!-- Posts Tab -->
            <LinearLayout
                android:id="@+id/tab_posts"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/icon_posts"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_grid" />

                <TextView
                    android:id="@+id/text_posts"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Posts"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Reels Tab -->
            <LinearLayout
                android:id="@+id/tab_reels"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/icon_reels"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_reels" />

                <TextView
                    android:id="@+id/text_reels"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reels"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Tagged Tab -->
            <LinearLayout
                android:id="@+id/tab_tagged"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/icon_tagged"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_tagged" />

                <TextView
                    android:id="@+id/text_tagged"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tagged"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- ==================== KONTEN POSTS ==================== -->
        <LinearLayout
            android:id="@+id/content_posts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <!-- GRID FEEDS DENGAN UKURAN 3:2 -->
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="400dp"
                android:scrollbars="vertical">

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="3"
                    android:padding="2dp">

                    <!-- ROW 1: Post 9, 8, 7 (TERBARU) - UKURAN 3:2 -->
                    <ImageView
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="1dp"
                        android:src="@drawable/ic_post_9"
                        android:scaleType="centerCrop"
                        android:contentDescription="Post 9" />

                    <ImageView
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="1dp"
                        android:src="@drawable/ic_post_8"
                        android:scaleType="centerCrop"
                        android:contentDescription="Post 8" />

                    <ImageView
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="1dp"
                        android:src="@drawable/ic_post_7"
                        android:scaleType="centerCrop"
                        android:contentDescription="Post 7" />

                    <!-- ROW 2: Post 6, 5, 4 - UKURAN 3:2 -->
                    <ImageView
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="1dp"
                        android:src="@drawable/ic_post_6"
                        android:scaleType="centerCrop"
                        android:contentDescription="Post 6" />

                    <ImageView
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="1dp"
                        android:src="@drawable/ic_post_5"
                        android:scaleType="centerCrop"
                        android:contentDescription="Post 5" />

                    <ImageView
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="1dp"
                        android:src="@drawable/ic_post_4"
                        android:scaleType="centerCrop"
                        android:contentDescription="Post 4" />

                    <!-- ROW 3: Post 3, 2, 1 (TERLAMA) - UKURAN 3:2 -->
                    <ImageView
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="1dp"
                        android:src="@drawable/ic_post_3"
                        android:scaleType="centerCrop"
                        android:contentDescription="Post 3" />

                    <ImageView
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="1dp"
                        android:src="@drawable/ic_post_2"
                        android:scaleType="centerCrop"
                        android:contentDescription="Post 2" />

                    <ImageView
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="1dp"
                        android:src="@drawable/ic_post_1"
                        android:scaleType="centerCrop"
                        android:contentDescription="Post 1" />

                </GridLayout>
            </ScrollView>
        </LinearLayout>

        <!-- ==================== KONTEN REELS (HIDDEN) ==================== -->
        <LinearLayout
            android:id="@+id/content_reels"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            android:background="#F8F8F8">

            <TextView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:text="🎬"
                android:textSize="40sp"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No Reels Yet"
                android:textSize="16sp"
                android:textColor="#8e8e8e"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- ==================== KONTEN TAGGED (HIDDEN) ==================== -->
        <LinearLayout
            android:id="@+id/content_tagged"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            android:background="#F8F8F8">

            <TextView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:text="🏷️"
                android:textSize="40sp"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No Tagged Posts"
                android:textSize="16sp"
                android:textColor="#8e8e8e"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- ==================== COMING SOON SECTION ==================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="#FFF3E0"
            android:layout_marginVertical="16dp"
            android:layout_marginHorizontal="16dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="COMING SOON"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#FF6B6B"
                android:letterSpacing="0.1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Something delicious is on the way!"
                android:textSize="14sp"
                android:textColor="#666666"
                android:layout_marginTop="8dp" />

            <ProgressBar
                android:layout_width="200dp"
                android:layout_height="4dp"
                android:indeterminate="true"
                android:layout_marginTop="16dp"
                style="?android:attr/progressBarStyleHorizontal" />
        </LinearLayout>

        <!-- ==================== HALAL SECTION ==================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="16dp"
            android:background="#E8F5E8"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            android:weightSum="3">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.5"
                android:text="✓"
                android:textSize="40sp"
                android:textColor="#4CAF50"
                android:gravity="center" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.5"
                android:text="HALAL"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#2E7D32"
                android:gravity="center" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Certified"
                android:textSize="14sp"
                android:textColor="#388E3C"
                android:gravity="center|bottom"
                android:paddingBottom="4dp" />
        </LinearLayout>

        <!-- ==================== BOTTOM NAVIGATION ==================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:layout_marginTop="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="24dp"
                android:layout_weight="1"
                android:text="🔍"
                android:textSize="20sp"
                android:gravity="center"
                android:textColor="#8e8e8e" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="24dp"
                android:layout_weight="1"
                android:text="🎬"
                android:textSize="20sp"
                android:gravity="center"
                android:textColor="#8e8e8e" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="24dp"
                android:layout_weight="1"
                android:text="❤️"
                android:textSize="20sp"
                android:gravity="center"
                android:textColor="#8e8e8e" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="24dp"
                android:layout_weight="1"
                android:text="👤"
                android:textSize="20sp"
                android:gravity="center"
                android:textColor="#3897F0" />
        </LinearLayout>

    </LinearLayout>
