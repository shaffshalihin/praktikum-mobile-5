<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── HEADER ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_header_username"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="username"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#000000" />

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_grid"
                android:layout_marginEnd="4dp"
                android:padding="2dp"
                android:alpha="0.0" />

            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="+"
                android:textSize="24sp"
                android:textColor="#000000"
                android:gravity="center"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="≡"
                android:textSize="24sp"
                android:textColor="#000000"
                android:gravity="center"
                android:background="?attr/selectableItemBackgroundBorderless" />
        </LinearLayout>

        <!-- ── PROFILE ROW ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp"
            android:gravity="center_vertical">

            <!-- Profile photo -->
            <FrameLayout
                android:layout_width="86dp"
                android:layout_height="86dp"
                android:layout_marginEnd="24dp">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/iv_foto_profil"
                    android:layout_width="86dp"
                    android:layout_height="86dp"
                    android:src="@drawable/ic_hodo_profile"
                    app:civ_border_width="0dp"
                    android:clickable="true"
                    android:focusable="true" />

                <!-- Camera badge -->
                <FrameLayout
                    android:id="@+id/tv_ganti_foto"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="bottom|end"
                    android:background="@drawable/bg_putih_lingkaran"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="+"
                        android:textSize="16sp"
                        android:textColor="#FFFFFF"
                        android:gravity="center"
                        android:background="@drawable/bg_circle_blue" />
                </FrameLayout>
            </FrameLayout>

            <!-- Stats -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/tv_posts"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="9"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="#000000" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="posts"
                        android:textSize="12sp"
                        android:textColor="#737373" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/tv_followers"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="#000000" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="followers"
                        android:textSize="12sp"
                        android:textColor="#737373" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/tv_following"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="#000000" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="following"
                        android:textSize="12sp"
                        android:textColor="#737373" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ── BIO ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="10dp">

            <TextView
                android:id="@+id/tv_nama"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#000000" />

            <TextView
                android:id="@+id/tv_bio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:textColor="#000000"
                android:lineSpacingExtra="2dp" />

            <TextView
                android:id="@+id/tv_link"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:textColor="#00376B"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- ── ACTION BUTTONS ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="12dp">

            <TextView
                android:id="@+id/btn_edit_profile"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:text="Edit Profile"
                android:gravity="center"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:background="@drawable/bg_button_gray_curvy"
                android:layout_marginEnd="4dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:text="Share Profile"
                android:gravity="center"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:background="@drawable/bg_button_gray_curvy"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp" />

            <TextView
                android:layout_width="36dp"
                android:layout_height="32dp"
                android:text="👤"
                android:gravity="center"
                android:textSize="16sp"
                android:background="@drawable/bg_button_gray_curvy"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <!-- ── STORY HIGHLIGHTS ── -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout android:layout_width="72dp" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center" android:layout_marginEnd="8dp">
                    <FrameLayout android:layout_width="62dp" android:layout_height="62dp">
                        <View android:layout_width="62dp" android:layout_height="62dp" android:background="@drawable/bg_highlight_gradient" />
                        <ImageView android:layout_width="56dp" android:layout_height="56dp" android:layout_gravity="center"
                            android:src="@drawable/ic_story_1" android:scaleType="centerCrop" android:background="@drawable/bg_circle" android:clipToOutline="true" android:outlineProvider="background" />
                    </FrameLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Sahoor" android:textSize="11sp" android:textColor="#262626" android:layout_marginTop="4dp" android:maxLines="1" android:ellipsize="end" />
                </LinearLayout>

                <LinearLayout android:layout_width="72dp" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center" android:layout_marginEnd="8dp">
                    <FrameLayout android:layout_width="62dp" android:layout_height="62dp">
                        <View android:layout_width="62dp" android:layout_height="62dp" android:background="@drawable/bg_highlight_gradient" />
                        <ImageView android:layout_width="56dp" android:layout_height="56dp" android:layout_gravity="center"
                            android:src="@drawable/ic_story_2" android:scaleType="centerCrop" android:background="@drawable/bg_circle" android:clipToOutline="true" android:outlineProvider="background" />
                    </FrameLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Iftar" android:textSize="11sp" android:textColor="#262626" android:layout_marginTop="4dp" android:maxLines="1" android:ellipsize="end" />
                </LinearLayout>

                <LinearLayout android:layout_width="72dp" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center" android:layout_marginEnd="8dp">
                    <FrameLayout android:layout_width="62dp" android:layout_height="62dp">
                        <View android:layout_width="62dp" android:layout_height="62dp" android:background="@drawable/bg_highlight_gradient" />
                        <ImageView android:layout_width="56dp" android:layout_height="56dp" android:layout_gravity="center"
                            android:src="@drawable/ic_story_3" android:scaleType="centerCrop" android:background="@drawable/bg_circle" android:clipToOutline="true" android:outlineProvider="background" />
                    </FrameLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Bulk" android:textSize="11sp" android:textColor="#262626" android:layout_marginTop="4dp" android:maxLines="1" android:ellipsize="end" />
                </LinearLayout>

                <LinearLayout android:layout_width="72dp" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center" android:layout_marginEnd="8dp">
                    <FrameLayout android:layout_width="62dp" android:layout_height="62dp">
                        <View android:layout_width="62dp" android:layout_height="62dp" android:background="@drawable/bg_highlight_gradient" />
                        <ImageView android:layout_width="56dp" android:layout_height="56dp" android:layout_gravity="center"
                            android:src="@drawable/ic_story_4" android:scaleType="centerCrop" android:background="@drawable/bg_circle" android:clipToOutline="true" android:outlineProvider="background" />
                    </FrameLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Menu" android:textSize="11sp" android:textColor="#262626" android:layout_marginTop="4dp" android:maxLines="1" android:ellipsize="end" />
                </LinearLayout>

                <LinearLayout android:layout_width="72dp" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center" android:layout_marginEnd="8dp">
                    <FrameLayout android:layout_width="62dp" android:layout_height="62dp">
                        <View android:layout_width="62dp" android:layout_height="62dp" android:background="@drawable/bg_highlight_gradient" />
                        <ImageView android:layout_width="56dp" android:layout_height="56dp" android:layout_gravity="center"
                            android:src="@drawable/ic_story_5" android:scaleType="centerCrop" android:background="@drawable/bg_circle" android:clipToOutline="true" android:outlineProvider="background" />
                    </FrameLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Ready" android:textSize="11sp" android:textColor="#262626" android:layout_marginTop="4dp" android:maxLines="1" android:ellipsize="end" />
                </LinearLayout>

            </LinearLayout>
        </HorizontalScrollView>

        <!-- ── DIVIDER ── -->
        <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#DBDBDB" />

        <!-- ── TABS ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/tab_posts"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:gravity="center">
                    <ImageView
                        android:id="@+id/icon_posts"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_grid" />
                </LinearLayout>
                <View
                    android:id="@+id/indicator_posts"
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="#000000"
                    android:visibility="visible" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/tab_reels"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:gravity="center">
                    <ImageView
                        android:id="@+id/icon_reels"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_reels" />
                </LinearLayout>
                <View
                    android:id="@+id/indicator_reels"
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="#000000"
                    android:visibility="invisible" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/tab_tagged"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:gravity="center">
                    <ImageView
                        android:id="@+id/icon_tagged"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_tagged" />
                </LinearLayout>
                <View
                    android:id="@+id/indicator_tagged"
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="#000000"
                    android:visibility="invisible" />
            </LinearLayout>

        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#DBDBDB" />

        <!-- ── POSTS GRID ── -->
        <LinearLayout
            android:id="@+id/content_posts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <ImageView android:id="@+id/iv_post_9" android:layout_width="0dp" android:layout_height="124dp" android:layout_weight="1" android:src="@drawable/ic_post_9" android:scaleType="centerCrop" android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackground" />
                <View android:layout_width="1.5dp" android:layout_height="match_parent" android:background="#FFFFFF" />
                <ImageView android:id="@+id/iv_post_8" android:layout_width="0dp" android:layout_height="124dp" android:layout_weight="1" android:src="@drawable/ic_post_8" android:scaleType="centerCrop" android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackground" />
                <View android:layout_width="1.5dp" android:layout_height="match_parent" android:background="#FFFFFF" />
                <ImageView android:id="@+id/iv_post_7" android:layout_width="0dp" android:layout_height="124dp" android:layout_weight="1" android:src="@drawable/ic_post_7" android:scaleType="centerCrop" android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackground" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1.5dp" android:background="#FFFFFF" />

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <ImageView android:id="@+id/iv_post_6" android:layout_width="0dp" android:layout_height="124dp" android:layout_weight="1" android:src="@drawable/ic_post_6" android:scaleType="centerCrop" android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackground" />
                <View android:layout_width="1.5dp" android:layout_height="match_parent" android:background="#FFFFFF" />
                <ImageView android:id="@+id/iv_post_5" android:layout_width="0dp" android:layout_height="124dp" android:layout_weight="1" android:src="@drawable/ic_post_5" android:scaleType="centerCrop" android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackground" />
                <View android:layout_width="1.5dp" android:layout_height="match_parent" android:background="#FFFFFF" />
                <ImageView android:id="@+id/iv_post_4" android:layout_width="0dp" android:layout_height="124dp" android:layout_weight="1" android:src="@drawable/ic_post_4" android:scaleType="centerCrop" android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackground" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1.5dp" android:background="#FFFFFF" />

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <ImageView android:id="@+id/iv_post_3" android:layout_width="0dp" android:layout_height="124dp" android:layout_weight="1" android:src="@drawable/ic_post_3" android:scaleType="centerCrop" android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackground" />
                <View android:layout_width="1.5dp" android:layout_height="match_parent" android:background="#FFFFFF" />
                <ImageView android:id="@+id/iv_post_2" android:layout_width="0dp" android:layout_height="124dp" android:layout_weight="1" android:src="@drawable/ic_post_2" android:scaleType="centerCrop" android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackground" />
                <View android:layout_width="1.5dp" android:layout_height="match_parent" android:background="#FFFFFF" />
                <ImageView android:id="@+id/iv_post_1" android:layout_width="0dp" android:layout_height="124dp" android:layout_weight="1" android:src="@drawable/ic_post_1" android:scaleType="centerCrop" android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackground" />
            </LinearLayout>

        </LinearLayout>

        <!-- ── REELS EMPTY ── -->
        <LinearLayout
            android:id="@+id/content_reels"
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🎬" android:textSize="48sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="No Reels Yet" android:textSize="16sp" android:textColor="#737373" android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- ── TAGGED EMPTY ── -->
        <LinearLayout
            android:id="@+id/content_tagged"
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🏷️" android:textSize="48sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="No Tagged Posts" android:textSize="16sp" android:textColor="#737373" android:layout_marginTop="8dp" />
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
