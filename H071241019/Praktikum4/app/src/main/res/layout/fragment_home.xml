<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_header_start"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="48dp"
        android:paddingBottom="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Good Reads"
            android:textColor="#FF6B6B"
            android:textSize="13sp"
            android:letterSpacing="0.12" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Discover Your\nNext Favorite Book"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:lineSpacingMultiplier="1.1"
            android:textStyle="bold" />

        <!-- Search Bar -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="24dp"
            app:cardBackgroundColor="@color/bg_search"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_search"
                    android:tint="@color/text_hint" />

                <EditText
                    android:id="@+id/et_search"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@null"
                    android:hint="Search by title..."
                    android:textColorHint="@color/text_hint"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:inputType="text"
                    android:imeOptions="actionSearch"
                    android:singleLine="true" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- Genre Chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_genres"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="false">

            <com.google.android.material.chip.Chip
                style="@style/GenreChip"
                android:text="All"
                android:checked="true" />
            <com.google.android.material.chip.Chip
                style="@style/GenreChip"
                android:text="Picture Books" />
            <com.google.android.material.chip.Chip
                style="@style/GenreChip"
                android:text="First Books" />
            <com.google.android.material.chip.Chip
                style="@style/GenreChip"
                android:text="See to Read" />
            <com.google.android.material.chip.Chip
                style="@style/GenreChip"
                android:text="Self Development" />
            <com.google.android.material.chip.Chip
                style="@style/GenreChip"
                android:text="Productivity" />
            <com.google.android.material.chip.Chip
                style="@style/GenreChip"
                android:text="Finance" />
            <com.google.android.material.chip.Chip
                style="@style/GenreChip"
                android:text="History" />
            <com.google.android.material.chip.Chip
                style="@style/GenreChip"
                android:text="Biography" />
            <com.google.android.material.chip.Chip
                style="@style/GenreChip"
                android:text="Thriller" />
            <com.google.android.material.chip.Chip
                style="@style/GenreChip"
                android:text="Fiction" />
            <com.google.android.material.chip.Chip
                style="@style/GenreChip"
                android:text="Psychology" />

        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <!-- Loading indicator pencarian -->
    <LinearLayout
        android:id="@+id/progress_search"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:visibility="gone">

        <ProgressBar
            style="?android:attr/progressBarStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminateTint="@color/accent_red" />
    </LinearLayout>

    <!-- Book List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_books"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="4dp"
        android:paddingBottom="16dp" />

</LinearLayout>