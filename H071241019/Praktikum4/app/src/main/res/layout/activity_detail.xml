<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Hero Banner -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="320dp">

            <View android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/gradient_detail_hero" />

            <!-- Back button -->
            <ImageView android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_margin="16dp"
                android:layout_marginTop="48dp"
                android:src="@drawable/ic_back"
                android:background="@drawable/circle_button_bg"
                android:padding="8dp"
                app:tint="@color/white" />

            <!-- Book cover -->
            <androidx.cardview.widget.CardView
                android:layout_width="140dp"
                android:layout_height="200dp"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="20dp">
                <ImageView android:id="@+id/detail_cover"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop" />
            </androidx.cardview.widget.CardView>

        </FrameLayout>

        <!-- Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView android:id="@+id/detail_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:gravity="center"
                android:fontFamily="sans-serif" />

            <TextView android:id="@+id/detail_author"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/accent_red"
                android:textSize="14sp"
                android:gravity="center"
                android:fontFamily="sans-serif" />

            <!-- Genre + Year -->
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="12dp">
                <TextView android:id="@+id/detail_genre"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:background="@drawable/pill_background"
                    android:backgroundTint="@color/accent_red_alpha"
                    android:textColor="@color/accent_red"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif" />
                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="·"
                    android:textColor="@color/text_hint"
                    android:textSize="16sp" />
                <TextView android:id="@+id/detail_year"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:textColor="@color/text_hint"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif" />
            </LinearLayout>

            <!-- Rating Box -->
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="16dp"
                android:padding="16dp"
                android:background="@drawable/round_card">
                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="COMMUNITY RATING"
                    android:textColor="@color/text_hint"
                    android:textSize="10sp"
                    android:letterSpacing="0.15"
                    android:fontFamily="sans-serif" />
                <TextView android:id="@+id/detail_rating_num"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/accent_yellow"
                    android:textSize="28sp"
                    android:fontFamily="sans-serif" />
                <RatingBar android:id="@+id/detail_rating_bar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:numStars="5"
                    android:stepSize="0.1"
                    android:isIndicator="true"
                    android:progressTint="@color/accent_yellow" />
            </LinearLayout>

            <!-- Like Button -->
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="16dp">
                <ImageView android:id="@+id/detail_like"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:src="@drawable/ic_favorite_border"
                    android:background="@drawable/circle_like_bg"
                    android:padding="14dp"
                    android:scaleType="fitCenter" />
                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="Add to Favorites"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif" />
            </LinearLayout>

            <!-- Divider -->
            <View android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="20dp"
                android:background="@color/divider" />

            <!-- Synopsis -->
            <TextView android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SYNOPSIS"
                android:textColor="@color/text_hint"
                android:textSize="10sp"
                android:letterSpacing="0.15"
                android:fontFamily="sans-serif"
                android:layout_marginBottom="8dp" />
            <TextView android:id="@+id/detail_blurb"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.7"
                android:fontFamily="sans-serif" />

            <!-- Divider -->
            <View android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="20dp"
                android:background="@color/divider" />

            <!-- Reader Review -->
            <TextView android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="READER REVIEW"
                android:textColor="@color/text_hint"
                android:textSize="10sp"
                android:letterSpacing="0.15"
                android:fontFamily="sans-serif"
                android:layout_marginBottom="8dp" />
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:background="@drawable/round_card">
                <View android:layout_width="4dp"
                    android:layout_height="match_parent"
                    android:background="@color/accent_red"
                    android:layout_marginEnd="12dp" />
                <TextView android:id="@+id/detail_review"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.6"
                    android:fontFamily="sans-serif"
                    android:fontStyle="italic" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="20dp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>