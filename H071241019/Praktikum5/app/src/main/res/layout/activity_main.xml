<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_pink">

    <!-- Blur circle decorations (behind content) -->
    <View
        android:id="@+id/blur_circle1"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-60dp"
        android:layout_marginEnd="-60dp"
        android:background="@drawable/bg_blur_circle_pink" />

    <View
        android:id="@+id/blur_circle2"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_gravity="bottom|start"
        android:layout_marginBottom="-50dp"
        android:layout_marginStart="-50dp"
        android:background="@drawable/bg_blur_circle_lavender" />

    <!-- Main scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="56dp"
            android:paddingBottom="40dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <!-- App Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="MuseCard ✨"
                android:textColor="@color/pink_dark"
                android:textSize="32sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="28dp" />

            <!-- Main Glass Card -->
            <LinearLayout
                android:id="@+id/main_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_glass_card"
                android:padding="24dp"
                android:gravity="center_horizontal"
                android:layout_marginBottom="16dp">

                <!-- Avatar -->
                <FrameLayout
                    android:layout_width="84dp"
                    android:layout_height="84dp"
                    android:layout_marginBottom="12dp">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_circle_avatar" />

                    <TextView
                        android:id="@+id/tv_initials"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:textColor="@color/white"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:text="?" />
                </FrameLayout>

                <!-- Name -->
                <TextView
                    android:id="@+id/tv_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your Name"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <!-- Genre Chip -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:id="@+id/tv_genre"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_chip_selected"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        android:text="Pop 🎤"
                        android:visibility="gone" />
                </LinearLayout>

                <!-- Mood Row -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:id="@+id/tv_mood_emoji"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="😊"
                        android:textSize="28sp"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/tv_mood_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Happy"
                        android:textColor="@color/text_secondary"
                        android:textSize="15sp" />
                </LinearLayout>

                <!-- Artist Row -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎤  "
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/tv_artist"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Not set yet"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- Volume -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🎚️  Volume"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <SeekBar
                        android:id="@+id/sb_volume"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:enabled="false"
                        android:progressTint="@color/pink_primary"
                        android:thumbTint="@color/pink_primary"
                        android:max="100"
                        android:progress="50" />

                    <TextView
                        android:id="@+id/tv_volume_value"
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:text="50%"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:gravity="center"
                        android:layout_marginStart="8dp" />
                </LinearLayout>

                <!-- Equalizer Bars -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="bottom">

                    <View
                        android:id="@+id/bar1"
                        android:layout_width="10dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_equalizer_bar" />

                    <View
                        android:id="@+id/bar2"
                        android:layout_width="10dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_equalizer_bar" />

                    <View
                        android:id="@+id/bar3"
                        android:layout_width="10dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_equalizer_bar" />
                </LinearLayout>

            </LinearLayout>

            <!-- Top Tracks Section (filled by iTunes API) -->
            <LinearLayout
                android:id="@+id/tracks_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_glass_card"
                android:padding="16dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🎵 Top Songs"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <ProgressBar
                    android:id="@+id/progress_tracks"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:indeterminateTint="@color/pink_primary" />

                <LinearLayout
                    android:id="@+id/tracks_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>

            <!-- Edit Profile Button -->
            <TextView
                android:id="@+id/btn_edit"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_button_pink"
                android:text="Edit Profile ✏️"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="12dp" />

            <!-- Settings Button -->
            <TextView
                android:id="@+id/btn_settings"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_button_glass"
                android:text="Settings ⚙️"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>
    </ScrollView>

    <!-- Floating flower decorations (above content) -->
    <ImageView
        android:id="@+id/flower1"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="top|start"
        android:layout_marginTop="48dp"
        android:layout_marginStart="12dp"
        android:src="@drawable/ic_flower_1"
        android:alpha="0.75"
        android:clickable="false"
        android:focusable="false" />

    <ImageView
        android:id="@+id/flower2"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="96dp"
        android:layout_marginEnd="20dp"
        android:src="@drawable/ic_flower_2"
        android:alpha="0.85"
        android:clickable="false"
        android:focusable="false" />

    <ImageView
        android:id="@+id/flower3"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="130dp"
        android:layout_marginEnd="16dp"
        android:src="@drawable/ic_flower_1"
        android:alpha="0.65"
        android:clickable="false"
        android:focusable="false" />

    <ImageView
        android:id="@+id/flower4"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_gravity="bottom|start"
        android:layout_marginBottom="200dp"
        android:layout_marginStart="18dp"
        android:src="@drawable/ic_flower_2"
        android:alpha="0.7"
        android:clickable="false"
        android:focusable="false" />

    <ImageView
        android:id="@+id/music_note1"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="160dp"
        android:layout_marginStart="80dp"
        android:src="@drawable/ic_music_note"
        android:alpha="0.4"
        android:clickable="false"
        android:focusable="false" />

    <ImageView
        android:id="@+id/music_note2"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_gravity="center_vertical|end"
        android:layout_marginEnd="28dp"
        android:src="@drawable/ic_music_note"
        android:alpha="0.3"
        android:clickable="false"
        android:focusable="false" />

</FrameLayout>
