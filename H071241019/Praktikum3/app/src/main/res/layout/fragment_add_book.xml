<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/bg_header_start"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="48dp"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="My Library"
                android:textColor="#FF6B6B"
                android:textSize="13sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add New Book 📚"
                android:textColor="@color/white"
                android:textSize="26sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Form Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Cover Preview -->
            <androidx.cardview.widget.CardView
                android:layout_width="120dp"
                android:layout_height="160dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardElevation="8dp">

                <LinearLayout
                    android:id="@+id/layout_no_cover"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📖"
                        android:textSize="32sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No Cover"
                        android:textColor="@color/text_hint"
                        android:textSize="11sp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/img_preview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone" />
            </androidx.cardview.widget.CardView>

            <!-- Pick Image Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_pick_image"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="20dp"
                android:text="📷  Pilih Cover dari Galeri"
                android:textColor="@color/white"
                android:textSize="13sp"
                app:backgroundTint="@color/bg_card"
                app:strokeColor="@color/accent_red"
                app:strokeWidth="1.5dp"
                app:cornerRadius="12dp" />

            <!-- Title -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/FormField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="Judul Buku">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Author -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/FormField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="Nama Penulis">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_author"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Year -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/FormField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="Tahun Terbit">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_year"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:textColor="@color/white" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Genre -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="Genre"
                app:boxStrokeColor="@color/accent_red"
                app:hintTextColor="@color/text_hint"
                app:boxBackgroundColor="@color/bg_card">
                <AutoCompleteTextView
                    android:id="@+id/spinner_genre"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:inputType="none" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Blurb -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/FormField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="Sinopsis / Blurb">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_blurb"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minLines="3"
                    android:gravity="top"
                    android:textColor="@color/white" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Review -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/FormField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="Ulasan Singkat">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_review"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minLines="2"
                    android:gravity="top"
                    android:textColor="@color/white" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Rating -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rating"
                android:textColor="@color/text_hint"
                android:textSize="13sp"
                android:layout_marginBottom="6dp" />
            <RatingBar
                android:id="@+id/rating_bar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:numStars="5"
                android:stepSize="0.5"
                android:progressTint="@color/accent_yellow" />

            <!-- Save Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Simpan Buku"
                android:textColor="@color/white"
                android:textSize="15sp"
                app:backgroundTint="@color/accent_red"
                app:cornerRadius="16dp"
                app:elevation="6dp" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>